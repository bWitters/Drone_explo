<?xml version="1.0"?>
<robot name="corridor" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- World link -->
  <link name="world"/>

  <!-- YAML path argument  -->
  <xacro:property name="config_yaml" value="croix.yaml"/>

  <!-- Load YAML -->
  <xacro:property name="CFG" value="${ xacro.load_yaml(config_yaml) }"/>

  <!-- Constants -->
  <xacro:property name="PI" value="${3.141592653589793}"/>

  <!-- Dimensions: L_in = clair-voie intérieure, L_out = dimension extérieure -->
  <xacro:property name="L_in"  value="${CFG['length']}"/>
  <xacro:property name="L_out" value="${CFG['length'] + 2*CFG['thk']}"/>

  <!-- Wall macro -->
  <xacro:macro name="wall" params="name x y yaw length thk height rgba">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 ${height/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${length} ${thk} ${height}"/>
        </geometry>
        <material name="${name}_mat">
          <color rgba="${rgba[0]} ${rgba[1]} ${rgba[2]} ${ (rgba[3] if len(rgba) > 3 else 1.0) }"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 ${height/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${length} ${thk} ${height}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0"/>
        <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
    <joint name="${name}_world" type="fixed">
      <origin xyz="${x} ${y} 0" rpy="0 0 ${yaw}"/>
      <parent link="world"/>
      <child link="${name}"/>
    </joint>
  </xacro:macro>

  <!-- Wall U -->
  <xacro:macro name="corridor_open"
             params="name x y yaw length width height thk rgba">

    <!-- compute rotation (cos/sin) and rotate local offsets -->
    <xacro:property name="_yaw" value="${float(yaw)}"/>
    <xacro:property name="_c" value="${math.cos(_yaw)}"/>
    <xacro:property name="_s" value="${math.sin(_yaw)}"/>

    <!-- Left wall local offset -->
    <xacro:property name="_left_dx" value="0"/>
    <xacro:property name="_left_dy" value="${width/2 + thk/2}"/>
    <xacro:property name="_left_x" value="${x + _left_dx*_c - _left_dy*_s}"/>
    <xacro:property name="_left_y" value="${y + _left_dx*_s + _left_dy*_c}"/>

    <!-- Mur gauche -->
    <xacro:wall
      name="${name}_left"
      x="${_left_x}"
      y="${_left_y}"
      yaw="${yaw}"
      length="${length}"
      thk="${thk}"
      height="${height}"
      rgba="${rgba}" />

    <!-- Right wall local offset -->
    <xacro:property name="_right_dx" value="0"/>
    <xacro:property name="_right_dy" value="${-(width/2 + thk/2)}"/>
    <xacro:property name="_right_x" value="${x + _right_dx*_c - _right_dy*_s}"/>
    <xacro:property name="_right_y" value="${y + _right_dx*_s + _right_dy*_c}"/>

    <!-- Mur droit -->
    <xacro:wall
      name="${name}_right"
      x="${_right_x}"
      y="${_right_y}"
      yaw="${yaw}"
      length="${length}"
      thk="${thk}"
      height="${height}"
      rgba="${rgba}" />

    <!-- Back wall local offset (behind, along -x) -->
    <xacro:property name="_back_dx" value="${-length/2}"/>
    <xacro:property name="_back_dy" value="0"/>
    <xacro:property name="_back_x" value="${x + _back_dx*_c - _back_dy*_s}"/>
    <xacro:property name="_back_y" value="${y + _back_dx*_s + _back_dy*_c}"/>

    <!-- Mur du fond -->
    <xacro:wall
      name="${name}_back"
      x="${_back_x}"
      y="${_back_y}"
      yaw="${yaw + PI/2}"
      length="${width + 2*thk}"
      thk="${thk}"
      height="${height}"
      rgba="${rgba}" />

  </xacro:macro>

  <!-- Room walls (positionnés pour que l'intérieur fasse L_in) -->
  <xacro:corridor_open
  name="corridor1"
  x="0.0"
  y="0.0"
  yaw="${PI/2}"
  length="${L_out}"
  width="${CFG['width']}"
  height="${CFG['height']}"
  thk="${CFG['thk']}"
  rgba="${CFG['rgba']}"/>

  <xacro:corridor_open
  name="corridor2"
  x="${L_out/2+CFG['width']/2}"
  y="${L_out/2+CFG['width']/2+CFG['thk']}"
  yaw="${PI}"
  length="${L_out}"
  width="${CFG['width']}"
  height="${CFG['height']}"
  thk="${CFG['thk']}"
  rgba="${CFG['rgba']}"/>

  <xacro:corridor_open
  name="corridor3"
  x="-${L_out/2+CFG['width']/2}"
  y="${L_out/2+CFG['width']/2+CFG['thk']}"
  yaw="${0.0}"
  length="${L_out}"
  width="${CFG['width']}"
  height="${CFG['height']}"
  thk="${CFG['thk']}"
  rgba="${CFG['rgba']}"/>

  <xacro:corridor_open
  name="corridor4"
  x="0.0"
  y="${L_out+CFG['width']+2*CFG['thk']}"
  yaw="${PI*3/2}"
  length="${L_out}"
  width="${CFG['width']}"
  height="${CFG['height']}"
  thk="${CFG['thk']}"
  rgba="${CFG['rgba']}"/>

</robot>